# ============================================================
# CrewMeld one-click deployment config — first time: cp .env.example .env
# ============================================================
# Empty secret fields are auto-generated by the setup container on first start (idempotent).
# Do NOT manually edit secrets once generated (especially ENCRYPTION_KEY).

# ── Image version ──
VERSION=latest

# ── Required ──
NEXT_PUBLIC_APP_URL=http://localhost:6100
# Application version
NEXT_PUBLIC_APP_VERSION=1.0
# Build date (YYYYMMDD), injected by CI/CD at package time; shows "dev" if empty locally
NEXT_PUBLIC_BUILD_DATE=
# ── Host IP (optional) ──
# Leave empty to let k3s-init auto-detect; fill manually for multi-NIC / VPN scenarios (e.g. 10.0.0.52)
# ⚠️ On some Windows Docker Desktop / WSL2 versions, auto-detection may return an IPv6 address,
#    which breaks skill endpoint URL format. Please fill in IPv4 manually in that case.
HOST_IP=

# ── Ports (only change on conflict) ──
APP_PORT=6100
SOCKET_PORT=6102
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Runtime mode ──
NODE_ENV=development
# Bypass login for E2E / development (must be false in production)
DISABLE_AUTH=false

# ── Secrets (leave empty for auto-generation; do not fill weak secrets manually) ──
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
# Connector credential encryption (crewmeld-specific, separate from ENCRYPTION_KEY above)
CONNECTOR_ENCRYPTION_KEY=
INTERNAL_API_SECRET=
# Used to sign ontology write confirmation tokens; MUST be overridden in production.
# Leave empty for auto-generation by the setup container, or set a strong random secret manually.
ONTOLOGY_CONFIRM_SECRET=

# ── Database ──
POSTGRES_USER=postgres
POSTGRES_DB=crewmeld
# Local dev (docker-compose.dev.yml) access; full stack uses db:5432 internally
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crewmeld

# ── Better-auth ──
BETTER_AUTH_URL=http://localhost:6100

# ── Redis (required by BullMQ + Socket.IO) ──
REDIS_URL=redis://localhost:6379
# Channel identity cache TTL in seconds (L1 in-process + L2 Redis); default 300 (5 min)
# IDENTITY_CACHE_TTL_SECONDS=300

# ── Storage ──
# local (filesystem) or s3 (MinIO / cloud S3)
STORAGE_PROVIDER=local

# ── Local LLM (optional) ──
OLLAMA_URL=http://host.docker.internal:11434
# Or alternative:
# DEEPSEEK_API_KEY=sk-xxx

# ── Log level ──
LOG_LEVEL=debug

# ── k3s skill sandbox pre-pull images (external K8s only) ──
# NOTE: the bundled k3s / k3s-init compose profile was removed; skill-Pod
# deployment now targets an external K8s (see K8S_API_SERVER below) or the
# OpenSandbox runtime (--profile opensandbox). Skill Pods use imagePullPolicy:
# Never, so these images must be pre-pulled into that cluster manually.
# Space-separated list.
K8S_PREPULL_IMAGES=node:22-bookworm python:3.12-bookworm

# ============================================================
# The variables below connect crewmeld to an external skill-pod K8s cluster.
# Uncomment and fill only when using the K8s skill-deployment feature.
# ============================================================

# ── External K8s (the bundled --profile k3s was removed; always external now) ──
# K8S_API_SERVER=https://10.0.0.50:6443
# K8S_API_TOKEN=eyJhbGc...
# K8S_NODE_IP=10.0.0.52
# K8S_DEPLOY_NAMESPACE=crewmeld-skills
# K8S_SKIP_TLS_VERIFY=true
# K8S_WARM_POOL_SIZE=3

# ── External MinIO (fill when --profile minio is not enabled) ──
# MINIO_ENDPOINT=http://your-host:9000
# MINIO_ACCESS_KEY=rag_flow
# MINIO_SECRET_KEY=infini_rag_flow
# MINIO_BUCKET=tool-files
# MINIO_PUBLIC_URL=http://your-host:9000

# ── External RAGFlow (fill when --profile ragflow is not enabled) ──
# RAGFLOW_URL=http://your-ragflow:9380

# ── OpenSandbox deploy dir (compose-only, --profile opensandbox = k3s runtime) ──
# Host path to the alibaba/OpenSandbox deploy directory that holds
# registries.yaml + shared-libs/ + sandbox-data/. The opensandbox-k3s service
# bind-mounts these. Defaults to a sibling of this repo; override if elsewhere.
# OPENSANDBOX_DEPLOY_DIR=../opensandbox-deploy

# ── OpenSandbox docker runtime (compose-only, --profile opensandbox-docker) ──
# Alternative to the k3s runtime: the opensandbox-server container drives the
# host Docker daemon (docker-out-of-docker). In this mode crewmeld connects via
# the compose network, so set: OPENSANDBOX_SERVER_URL=http://opensandbox-server:30080
# The server's own api_key is rendered from OPENSANDBOX_API_KEY (Dev Studio
# section below) — set it before starting this profile, or the server stays insecure.
#
# HOST path used as the sandbox volume root + allowed_host_paths allowlist.
# Substituted into .sandbox.toml at startup AND bind-mounted into the server at
# the identical path (so host-daemon bind mounts resolve). Must be a HOST path.
CREWMELD_SANDBOX_VOLUME_ROOT=/data/opensandbox-deploy
# Published server port.
OPENSANDBOX_PORT=30080
# Images (override tags / point at a mirror here). crewmeld-coder reuses
# CREWMELD_SANDBOX_IMAGE from the Dev Studio section below.
OPENSANDBOX_SERVER_IMAGE=opensandbox/server:v0.1.14
OPENSANDBOX_EXECD_IMAGE=opensandbox/execd:v1.0.16
OPENSANDBOX_EGRESS_IMAGE=opensandbox/egress:v1.0.12
OPENSANDBOX_BASE_IMAGE=python:3.12-slim

# ===== Dev Studio (Tool Development Workspace, Sub-spec A) =====
# Enable startup env validation when 1; not 1 = skipped
DEV_STUDIO_ENABLED=0

# OpenSandbox connection (required when DEV_STUDIO_ENABLED=1).
# docker runtime (--profile opensandbox-docker): the server is a compose service,
#   reachable over the compose network by name → http://opensandbox-server:30080
# k3s / external server: point at that server's URL instead.
OPENSANDBOX_SERVER_URL=http://opensandbox-server:30080
OPENSANDBOX_API_KEY=
# Route sandbox webui/exec traffic through the server's reverse-proxy path
# (${OPENSANDBOX_SERVER_URL}/v1/sandboxes/<id>/proxy/<port>/) instead of the raw
# sandbox address returned by getSandboxEndpoint.
# docker runtime: MUST be 1 — crewmeld and the spawned sandbox containers live on
#   different docker networks, so the direct sandbox IP is unreachable; the server
#   proxies. k3s in-cluster: 0 is fine (direct pod path, one hop fewer).
OPENSANDBOX_USE_PROXY=1

# Sandbox image (defaults to proinsight/crewmeld-coder:latest)
CREWMELD_SANDBOX_IMAGE=proinsight/crewmeld-coder:latest

# Sandbox TTL in seconds (default 7200 = 2h)
CREWMELD_SANDBOX_TTL_SECONDS=7200

# REQUIRED for Dev Studio. HOST root from which ALL crewmeld-side host paths
# derive via the paths facade (sessions/, workspaces/, tools-workspace/,
# shared-libs/). The crewmeld container runs as a non-root user; the `host-prep`
# compose service automatically chmod's this dir to 1777 on startup (works on
# Linux and Windows/macOS Docker Desktop). Usually the same directory as
# CREWMELD_SANDBOX_VOLUME_ROOT above.
CREWMELD_BFF_VOLUME_ROOT=/data/opensandbox-deploy

# Optional pip index mirror. When set, the container writes /root/.pip/pip.conf
# Speeds up python package installs from inside the sandbox (China network).
# Example: https://pypi.tuna.tsinghua.edu.cn/simple
# CREWMELD_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple


# ===== Dev Studio fresh-sandbox tool validation (Sub-spec B) =====
# NOTE: the tools-workspace/ and shared-libs/ host paths now derive from
# CREWMELD_BFF_VOLUME_ROOT (paths facade). The former CREWMELD_TOOLS_WORKSPACE_DIR
# and CREWMELD_SHARED_LIBS_DIR env vars are deprecated and ignored.
# Extra egress domains appended to every sandbox network policy (comma-separated).
# Example: internal-registry.corp.local,api.internal.svc
CREWMELD_SANDBOX_SYSTEM_EGRESS=
# pip index-url injected into builder + test sandboxes (China mirror).
# Example: https://pypi.tuna.tsinghua.edu.cn/simple
CREWMELD_SANDBOX_PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
