# ============================================================
# CrewMeld one-click deployment config — first time: cp .env.example .env
# ============================================================
# Empty secret fields are auto-generated by the setup container on first start (idempotent).
# Do NOT manually edit secrets once generated (especially ENCRYPTION_KEY).

# ── Image version ──
VERSION=latest

# ── Required ──
NEXT_PUBLIC_APP_URL=http://localhost:6100
# Application version
NEXT_PUBLIC_APP_VERSION=1.0
# Build date (YYYYMMDD), injected by CI/CD at package time; shows "dev" if empty locally
NEXT_PUBLIC_BUILD_DATE=
# ── Host IP (optional) ──
# Leave empty to let k3s-init auto-detect; fill manually for multi-NIC / VPN scenarios (e.g. 10.0.0.52)
# ⚠️ On some Windows Docker Desktop / WSL2 versions, auto-detection may return an IPv6 address,
#    which breaks skill endpoint URL format. Please fill in IPv4 manually in that case.
HOST_IP=

# ── Ports (only change on conflict) ──
APP_PORT=6100
SOCKET_PORT=6102
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Runtime mode ──
NODE_ENV=development
# Bypass login for E2E / development (must be false in production)
DISABLE_AUTH=false

# ── Secrets (leave empty for auto-generation; do not fill weak secrets manually) ──
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
# Connector credential encryption (crewmeld-specific, separate from ENCRYPTION_KEY above)
CONNECTOR_ENCRYPTION_KEY=
INTERNAL_API_SECRET=

# ── Database ──
POSTGRES_USER=postgres
POSTGRES_DB=crewmeld
# Local dev (docker-compose.dev.yml) access; full stack uses db:5432 internally
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crewmeld

# ── Better-auth ──
BETTER_AUTH_URL=http://localhost:6100

# ── Redis (required by BullMQ + Socket.IO) ──
REDIS_URL=redis://localhost:6379

# ── Storage ──
# local (filesystem) or s3 (MinIO / cloud S3)
STORAGE_PROVIDER=local

# ── Local LLM (optional) ──
OLLAMA_URL=http://host.docker.internal:11434
# Or alternative:
# DEEPSEEK_API_KEY=sk-xxx

# ── Log level ──
LOG_LEVEL=debug

# ── k3s skill sandbox pre-pull images (only effective with --profile k3s) ──
# Skill Pods deployed by Crewmeld use imagePullPolicy: Never, so images must be pre-pulled into k3s.
# Space-separated list. First start pulls each image in 2-10 minutes (depends on bandwidth).
K8S_PREPULL_IMAGES=node:22-bookworm python:3.12-bookworm

# ============================================================
# The variables below are usually not needed — auto-injected into autogen.env by k3s-init.
# Uncomment and fill only when connecting to external services.
# ============================================================

# ── External K8s (fill when --profile k3s is not enabled) ──
# K8S_API_SERVER=https://10.0.0.50:6443
# K8S_API_TOKEN=eyJhbGc...
# K8S_NODE_IP=10.0.0.52
# K8S_DEPLOY_NAMESPACE=crewmeld-skills
# K8S_SKIP_TLS_VERIFY=true
# K8S_WARM_POOL_SIZE=3

# ── External MinIO (fill when --profile minio is not enabled) ──
# MINIO_ENDPOINT=http://your-host:9000
# MINIO_ACCESS_KEY=rag_flow
# MINIO_SECRET_KEY=infini_rag_flow
# MINIO_BUCKET=tool-files
# MINIO_PUBLIC_URL=http://your-host:9000

# ── External RAGFlow (fill when --profile ragflow is not enabled) ──
# RAGFLOW_URL=http://your-ragflow:9380

# ===== Dev Studio (Tool Development Workspace, Sub-spec A) =====
# Enable startup env validation when 1; not 1 = skipped
DEV_STUDIO_ENABLED=0

# OpenSandbox connection (required when DEV_STUDIO_ENABLED=1)
OPENSANDBOX_SERVER_URL=http://localhost:8080
OPENSANDBOX_API_KEY=
# Set to 1 when crewmeld runs outside the OpenSandbox k8s cluster (e.g. dev
# workstation against a remote OpenSandbox). Routes webui traffic through the
# server's reverse-proxy path instead of the raw pod ClusterIP that
# getSandboxEndpoint returns by default. Leave unset / =0 for in-cluster
# deployments (e.g. k3s prod) — direct pod path is one hop fewer.
OPENSANDBOX_USE_PROXY=0

# Sandbox image (defaults to proinsight/crewmeld-coder:latest)
CREWMELD_SANDBOX_IMAGE=proinsight/crewmeld-coder:latest

# Sandbox TTL in seconds (default 7200 = 2h)
CREWMELD_SANDBOX_TTL_SECONDS=7200

# Host root for per-session directories. Each session creates
CREWMELD_SESSIONS_DIR=/data/opensandbox-deploy/sandbox-data/sessions

# Optional pip index mirror. When set, the container writes /root/.pip/pip.conf
# Speeds up python package installs from inside the sandbox (China network).
# Example: https://pypi.tuna.tsinghua.edu.cn/simple
# CREWMELD_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# A.min default ANTHROPIC injection (C phase will replace with per-connection coder config)
# When DEV_STUDIO_ENABLED=1, ANTHROPIC_AUTH_TOKEN is required; the rest have defaults.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_SMALL_FAST_MODEL=

# ===== Dev Studio fresh-sandbox tool validation (Sub-spec B) =====
# Host directory for extracted .cmtool code + per-execution IO workspace.
# Layout: <dir>/<toolId>/code/ (RO) + <dir>/io/<executionId>/ (RW)
CREWMELD_TOOLS_WORKSPACE_DIR=/data/opensandbox-deploy/sandbox-data/tools-workspace
# Shared pip site-packages cache keyed by sha256(libraries).
# Layout: <dir>/<hash>/site-packages/ + <dir>/<hash>/.ready
CREWMELD_SHARED_LIBS_DIR=/data/opensandbox-deploy/sandbox-data/shared-libs
# Extra egress domains appended to every sandbox network policy (comma-separated).
# Example: internal-registry.corp.local,api.internal.svc
CREWMELD_SANDBOX_SYSTEM_EGRESS=
# pip index-url injected into builder + test sandboxes (China mirror).
# Example: https://pypi.tuna.tsinghua.edu.cn/simple
CREWMELD_SANDBOX_PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
