{
  "name": "crewmeld",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.2.13",
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --port 6100 --hostname 0.0.0.0",
    "dev:webpack": "next dev --webpack",
    "dev:sockets": "bun run socket/index.ts",
    "dev:full": "bunx concurrently -n \"App,Realtime\" -c \"cyan,magenta\" \"bun run dev\" \"bun run dev:sockets\"",
    "build": "next build --webpack",
    "build:socket": "bun build ./socket/index.ts --target=bun --outfile=./socket-bundled.js --external=sharp '--external=@img/*' '--external=@opentelemetry/*' --external=unpdf --external=iconv-lite --external=ws --external=tiktoken",
    "start": "next start --port 6100 --hostname 0.0.0.0",
    "start:full": "bunx concurrently -n \"App,Realtime\" -c \"cyan,magenta\" \"bun run start\" \"bun run dev:sockets\"",
    "prepare": "cd ../.. && bun husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "email:dev": "email dev --dir components/emails",
    "type-check": "tsc --noEmit",
    "generate-docs": "bun run ../../scripts/generate-docs.ts",
    "rotate-keys": "bun run scripts/rotate-keys.ts",
    "dev:seed": "bun run scripts/seed-dev.ts",
    "migrate:openclaw-endpoints": "bun run scripts/migrate-openclaw-endpoints.ts",
    "cleanup:archived-dev-sessions": "bun run scripts/cleanup-archived-dev-sessions.ts"
  },
